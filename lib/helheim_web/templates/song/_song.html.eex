<div class="media mb-1">
  <%= render "_cover.html", href: song_path(@conn, :show, @song), image_url: @song.cover_image_url_small %>
  <div class="media-body">
    <%= link @song.title, to: song_path(@conn, :show, @song) %>
    <br>
    <small class="text-muted"><%= @song.artist_name %></small>
    <br>
    <%= comment_count_badge @song %>
    <%= if assigns[:listen_count] do %>
      <%= listen_count_badge @listen_count %>
    <% end %>
  </div>
</div>
